void loop() {


  switch (stage) {
    case 0:
      lcd.setCursor(0, 0);
      lcd.print("Are you female?");
      lcd.setCursor(0, 1);
      lcd.print("YES[ ]  NO[ ]");
      readButtons();
      stage++;
      break;


    case 1:
      lcd.setCursor(0, 0);
      lcd.print("Pregnant?");
      lcd.setCursor(0, 1);
      lcd.print("YES[ ]  NO[ ]");
      readButtons();
      stage++;
      break;


    case 2:
      lcd.setCursor(0, 0);
      lcd.print("Enter Sample");
      delay(2000);
      stage++;
      break;


    case 3:
      lcd.setCursor(0, 0);
      lcd.print("Analyzing...");
      delay(3000);
      stage++;
      break;


    case 4:
      iodine();
      while (true); // end program
  }
}


bool i2CAddrTest(uint8_t addr)
{
  Wire.beginTransmission(addr);
  return (Wire.endTransmission() == 0);
}


byte readButtons()
{
  while (true) {
    if (digitalRead(buttonPins[1]) == LOW) {
      delay(200);
      return 1;
    }
    if (digitalRead(buttonPins[0]) == LOW) {
      delay(200);
      return 0;
    }
  }
}




